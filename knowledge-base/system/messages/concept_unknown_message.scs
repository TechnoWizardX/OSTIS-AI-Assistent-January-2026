// first production
@unknown_reply = [Извини, я пока не знаю, как на это ответить.

Попробуй переформулировать команду или уточнить детали — я всегда готов помочь!];;

@production = {
    rrel_reply_template: {
		rrel_message_template: @unknown_reply
	}
};;
@production <- nrel_reply_production;;
// -------------------

// message topic class

concept_unknown_message
<- sc_node_class;
=> nrel_main_idtf:
    [класс неизвестных сообщений]
    (*
        <- lang_ru;;
    *);
<- concept_message_topic;
<= nrel_inclusion:
    concept_message;
=> nrel_reply_production_chain: <
    @production
>;;
