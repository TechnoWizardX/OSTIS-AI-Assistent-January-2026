//////////////////////////////////////
// Greetings
//////////////////////////////////////

// --- First production: student already greeted and I have positive mood

@student_already_greeted_and_i_have_positive_mood_reply_template =
[Привет снова, ${concept_student}! 😊

Как твои дела? Я в отличном настроении и готова помочь 🚀

Спрашивай, что угодно, или набери "Помощь", чтобы узнать, чем я могу тебе помочь! 😀];;

@if_student_already_greeted_and_i_have_positive_mood_production = {
    rrel_condition_template: {
        rrel_template: [*
            @input_param1 = (.._student <-_ concept_student);;
            myself <-_ concept_intelligent_system;;
            myself <-_ concept_mood_positive;;
            nrel_greeted_user _-> (myself _=> .._student);;
        *];
        rrel_template_input_params: {
            @input_param1
        }
    } (* <- nrel_search_template;; *);
    rrel_reply_template: {
		rrel_message_template: @student_already_greeted_and_i_have_positive_mood_reply_template
	}
};;
@if_student_already_greeted_and_i_have_positive_mood_production <- nrel_reply_production;;

// --- Second production: student already greeted and I have neutral mood

@student_already_greeted_and_i_have_neutral_mood_reply_template =
[Привет ещё раз, ${concept_student}! 👋

Что обсудим сейчас?

Если не знаешь, с чего начать, введи "Помощь". 😊];;

@if_student_already_greeted_and_i_have_neutral_mood_production = {
    rrel_condition_template: {
        rrel_template: [*
            @input_param1 = (.._student <-_ concept_student);;
            myself <-_ concept_intelligent_system;;
            myself <-_ concept_mood_neutral;;
            nrel_greeted_user _-> (myself _=> .._student);;
        *];
        rrel_template_input_params: {
            @input_param1
        }
    } (* <- nrel_search_template;; *);
    rrel_reply_template: {
		rrel_message_template: @student_already_greeted_and_i_have_neutral_mood_reply_template
	}
};;
@if_student_already_greeted_and_i_have_neutral_mood_production <- nrel_reply_production;;

// --- Third production: student already greeted and I have tired mood

