//////////////////////////////////////
// Search my skills
//////////////////////////////////////

// --- First production: skills found

@skills_found_reply_template = [🛠️ Я могу:
#foreach
${foreach.item.index}) ${concept_skills}:
    #foreach
    •${concept_skill} ⚙️:

        Например:
        #foreach
            ◦"${concept_example}"#if(${foreach.hasNext}),#cwf#else.#endif
        #endfor
#cwb#endfor
#cwb#endfor

❗️ Просто задай одину из перечисленных комманд — и я сразу помогу! 🤗];;

@if_skills_found_production = {
    rrel_condition_template: {
        rrel_init_template: {
            rrel_template: [*
                nrel_skills _-> (.._skills <=_ myself);;
                @output_param1 = (.._skills <-_ concept_skills);;
            *];
            rrel_template_output_params: {
                @output_param1
            }
        } (* <- nrel_search_set_template;; *);
        rrel_next_template: {
            rrel_init_template: {
                rrel_template: [*
                    @input_param1 = (.._skills <-_ concept_skills);;
                    .._skill <-_ .._skills;;
                    @output_param1 = (.._skill <-_ concept_skill);;
                *];
                rrel_template_input_params: {
                    @input_param1
                };
                rrel_template_output_params: {
                    @output_param1
                }
            } (* <- nrel_search_set_template;; *);
            rrel_next_template: {
                rrel_init_template: {
                    rrel_template: [*
                        @input_param1 = (.._skill <-_ concept_skill);;
                        nrel_corresponding_skill _-> (.._message_class _=> .._skill);;
                        nrel_inclusion _-> (concept_student_message _=> .._message_class);;
                        nrel_example _-> (.._example <=_ .._message_class);;
                        .._example <-_ concept_example;;
                    *];
                    rrel_template_input_params: {
                        @input_param1
                    }
                } (* <- nrel_search_set_template;; *)
            } (* <- nrel_fixed_search_strategy_template;; *)
        } (* <- nrel_fixed_search_strategy_template;; *)
    } (* <- nrel_fixed_search_strategy_template;; *);
    rrel_reply_template: {
		rrel_message_template: @skills_found_reply_template
	}
};;
@if_skills_found_production <- nrel_reply_production;;

// --- Message topic class

concept_student_message_about_searching_my_skills
<- sc_node_class;
=> nrel_main_idtf:
    [класс сообщений учащихся о запросе моих навыков]
    (*
        <- lang_ru;;
    *);
<- concept_message_topic;
<= nrel_inclusion:
    concept_student_message;
=> nrel_corresponding_skill:
    ...
    (*
        => nrel_main_idtf:
            [найти всё, что я могу сделать для тебя]
            (*
                <- lang_ru;;
            *);;
        <- concept_skill;;
        <- .help_students;;
    *);
=> nrel_example:
    [Что ты умеешь делать?]
    (*
        <- concept_example;;
    *);
=> nrel_reply_production_chain: <
    @if_skills_found_production
>;
=> nrel_message_keywords: [
    что ты умеешь делать;
    что умеешь;
    зачем ты нужен;
    какие у тебя навыки;
    какие у тебя скилы;
    скинь свои скилы;
    расскажи, что ты умеешь;
];
=> nrel_message_patterns: [
];;
